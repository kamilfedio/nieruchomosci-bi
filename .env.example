# Copy this file to .env and fill in your values.
# .env is gitignored — never commit it.

# ── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+psycopg2://airflow:airflow@localhost:5432/nieruchomosci

# ── External API keys ────────────────────────────────────────────────────────
KAGGLE_API_TOKEN=
GEMINI_API_KEY=
BDL_API_KEY=
GOOGLE_MAPS_API_KEY=

# ── Pipeline tuning (optional — defaults shown) ──────────────────────────────
KAGGLE_DATASET_SLUG=krzysztofjamroz/apartment-prices-in-poland
GOV_DATA_BATCH_SIZE=500
GOV_DATA_SCRAPE_WORKERS=12
GEOCODE_WORKERS=8
GEMINI_TIMEOUT_MS=60000
