# Copy this file to .env and fill in your values.
# .env is gitignored — never commit it.

# ── Database ────────────────────────────────────────────────────────────────
# Superuser connection for ETL pipelines and DDL (Airflow)
DATABASE_URL=postgresql+psycopg2://airflow:airflow@localhost:5432/nieruchomosci
# Read-only connection for the Streamlit dashboard (analyst_ro role)
ANALYST_DATABASE_URL=postgresql+psycopg2://analyst_ro:analyst@localhost:5432/nieruchomosci

# ── Dashboard login (SHA-256 hex hashes) ────────────────────────────────────
# Generate: python3 -c "import hashlib; print(hashlib.sha256(b'YOUR_PASS').hexdigest())"
ADMIN_PASSWORD_HASH=8c6976e5b5410415bde908bd4dee15dfb167a9c873fc4bb8a81f6f2ab448a918
ANALYST_PASSWORD_HASH=f44ceb062e35dfeea6ed7f8524d53bb0bff19f553e25cae7ef4850e4185ccbba

# ── External API keys ────────────────────────────────────────────────────────
KAGGLE_API_TOKEN=
GEMINI_API_KEY=
BDL_API_KEY=
GOOGLE_MAPS_API_KEY=

# ── Pipeline tuning (optional — defaults shown) ──────────────────────────────
KAGGLE_DATASET_SLUG=krzysztofjamroz/apartment-prices-in-poland
GOV_DATA_BATCH_SIZE=500
GOV_DATA_SCRAPE_WORKERS=12
GEOCODE_WORKERS=8
GEMINI_TIMEOUT_MS=60000
